# 耳边 VPS 部署环境变量
# 复制为 .env，填好后执行 docker compose up -d --build

# ========= 对外暴露 =========
# web 容器映射到主机的端口；如果前置还有 Caddy/Nginx，改成 8080 之类
WEB_PORT=80

# Directus 自报的公网地址（含协议），用于生成文件 URL、重置邮件等
PUBLIC_URL=https://admin.your-domain.com

# 前端构建时写死的 API 前缀。默认 /api 走同域反代，不用改
VITE_API_BASE_URL=/api

# 前端访问 Directus 的允许来源（空格逗号分隔，不带尾斜杠）
# 若前端与后端同域走 /api，可以填 *
CORS_ORIGIN=*

# ========= 数据库 =========
POSTGRES_USER=directus
POSTGRES_DB=directus
POSTGRES_PASSWORD=改成强密码_32位以上随机

# ========= Directus 管理员 =========
# 首次启动用这个账号创建超管；后续登录用这组凭据
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=改成强密码

# Directus 内部加密 key/secret（用 openssl rand -base64 32 生成两个）
DIRECTUS_KEY=openssl-rand-base64-32-替换
DIRECTUS_SECRET=openssl-rand-base64-32-替换

# ========= 上传大小 =========
FILES_MAX_UPLOAD_SIZE=200mb

# ========= 存储 =========
# 默认 local：文件存 docker volume `uploads`
# 要用 Cloudflare R2，把 STORAGE_LOCATIONS 改成 r2，并填下面的 token
STORAGE_LOCATIONS=local

# R2（可选，推荐生产用）
# STORAGE_LOCATIONS=r2
# STORAGE_R2_DRIVER=s3
# STORAGE_R2_KEY=
# STORAGE_R2_SECRET=
# STORAGE_R2_BUCKET=erbian-media
# STORAGE_R2_REGION=auto
# STORAGE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# STORAGE_R2_FORCE_PATH_STYLE=true
# STORAGE_R2_ROOT=https://cdn.your-domain.com/
