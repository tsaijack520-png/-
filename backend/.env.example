# ============= Directus 基础 =============
# 随机 32+ 位字符串，生产必须改
KEY=change-me-random-32-chars
SECRET=change-me-random-32-chars

# 管理员账号，首次启动自动创建
ADMIN_EMAIL=admin@erbian.fm
ADMIN_PASSWORD=change-me

# 后台对外访问地址（Railway 会自动给 xxx.up.railway.app，或填自定义域名）
PUBLIC_URL=https://erbian-admin.up.railway.app

# ============= 数据库 =============
# Railway 的 Postgres 会自动注入 DATABASE_URL，本地用分字段配置即可
DB_CLIENT=pg
DB_HOST=database
DB_PORT=5432
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=directus

# ============= 缓存（可选）=============
CACHE_ENABLED=true
CACHE_STORE=redis
REDIS=redis://cache:6379

# ============= 对象存储（Cloudflare R2）=============
# 正式环境用 R2；本地 dev 可保持 local 驱动
STORAGE_LOCATIONS=r2
STORAGE_R2_DRIVER=s3
STORAGE_R2_KEY=your-r2-access-key-id
STORAGE_R2_SECRET=your-r2-secret-access-key
STORAGE_R2_BUCKET=erbian-media
STORAGE_R2_REGION=auto
STORAGE_R2_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
STORAGE_R2_FORCE_PATH_STYLE=true
# 可选：R2 绑定自定义公开域名，获得永久公开 URL；不绑定就用 Directus 转发
STORAGE_R2_ROOT=

# ============= CORS =============
# 允许前端域名访问（逗号分隔）
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5173,https://tsaijack520-png.github.io

# ============= 上传限制 =============
# 音频单文件最大 200MB
FILES_MAX_UPLOAD_SIZE=200mb

# ============= 邮件（可选，不填则部分功能受限但能跑）=============
EMAIL_FROM=no-reply@erbian.fm
EMAIL_TRANSPORT=sendmail
